{
  "manifest_version": 3,
  "name": "Aily Runtime Log Exporter",
  "version": "0.1.0",
  "description": "Export selected Feishu Aily runtime trace logs as JSON.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Aily Log Export",
    "default_popup": "src/popup.html"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://feishu.cn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://feishu.cn/ai/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-hook.js"
      ],
      "matches": [
        "https://feishu.cn/*"
      ]
    }
  ]
}

